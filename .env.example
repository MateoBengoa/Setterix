NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
META_APP_ID=
META_APP_SECRET=
# Facebook Login for Business → Configurations (required for Instagram connect with config_id)
META_BUSINESS_LOGIN_CONFIG_ID=
# Optional: loginpage = use business/loginpage + “Log in with Instagram” (omit or direct for default; localhost always uses direct unless ?entry=loginpage)
# META_BUSINESS_LOGIN_ENTRY=loginpage
# OAuth redirect: {NEXT_PUBLIC_APP_URL}/api/integrations/meta/callback
# Add this URL in Facebook Login for Business settings AND Facebook Login → Valid OAuth Redirect URIs.
META_WEBHOOK_VERIFY_TOKEN=
DODO_SECRET_KEY=
DODO_WEBHOOK_SECRET=
CALCOM_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
# Must match how you open the app (port + host). Add same URLs in Supabase Auth → Redirect URLs.
# If you see 431 Request Header Fields Too Large: clear site data for localhost (cookies) or keep using npm run dev (header limit is raised in package.json).
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_AGENT_SECRET=
NEXT_PUBLIC_DODO_CHECKOUT_BASE=
NEXT_PUBLIC_DODO_PORTAL_BASE=
SUPABASE_EDGE_PROCESS_URL=
